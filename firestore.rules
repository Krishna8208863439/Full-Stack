rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions for security
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function hasRole(role) {
      return isAuthenticated() && (
        getUserData().roleId == role || getUserData().roleId == 'admin'
      );
    }

    function isNotDeleted() {
      return resource == null || resource.data.isDeleted == false;
    }

    // Collection security rules
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if hasRole('admin') || request.auth.uid == userId;
      allow delete: if hasRole('admin');
    }

    match /roles/{roleId} {
      allow read: if isAuthenticated();
      allow write: if hasRole('admin');
    }

    match /machines/{machineId} {
      allow read: if isAuthenticated() && isNotDeleted();
      allow write: if hasRole('admin') || hasRole('plant_manager') || hasRole('supervisor');
    }

    match /production/{productionId} {
      allow read: if isAuthenticated() && isNotDeleted();
      allow write: if hasRole('admin') || hasRole('plant_manager') || hasRole('supervisor');
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated() && isNotDeleted();
      allow write: if hasRole('admin') || hasRole('plant_manager');
    }

    match /customers/{customerId} {
      allow read: if isAuthenticated() && isNotDeleted();
      allow write: if hasRole('admin') || hasRole('plant_manager');
    }

    match /suppliers/{supplierId} {
      allow read: if isAuthenticated() && isNotDeleted();
      allow write: if hasRole('admin') || hasRole('plant_manager');
    }

    match /inventory/{yarnId} {
      allow read: if isAuthenticated() && isNotDeleted();
      allow write: if hasRole('admin') || hasRole('plant_manager') || hasRole('supervisor');
    }

    match /stock/{stockId} {
      allow read: if isAuthenticated() && isNotDeleted();
      allow write: if hasRole('admin') || hasRole('plant_manager') || hasRole('quality_inspector');
    }

    match /attendance/{attendanceId} {
      allow read: if isAuthenticated();
      allow write: if hasRole('admin') || hasRole('plant_manager') || hasRole('supervisor');
    }

    match /maintenance/{ticketId} {
      allow read: if isAuthenticated();
      allow write: if hasRole('admin') || hasRole('plant_manager') || hasRole('maintenance_tech') || hasRole('supervisor');
    }

    match /quality/{inspectionId} {
      allow read: if isAuthenticated();
      allow write: if hasRole('admin') || hasRole('quality_inspector');
    }

    match /reports/{reportId} {
      allow read: if isAuthenticated();
      allow write: if hasRole('admin') || hasRole('plant_manager');
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if hasRole('admin');
    }

    match /activity_logs/{logId} {
      allow read: if hasRole('admin') || hasRole('plant_manager');
      allow create: if isAuthenticated();
      allow update, delete: if false; // Immutable logs
    }
  }
}
